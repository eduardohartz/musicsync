# ─── Web panel (the primary way to set up and run musicsync) ─────────────────
# The panel starts only when one of these is set. First launch opens a setup
# wizard that walks through credentials, account connection, playlist
# selection, and scheduling — no other configuration needed.
WEB_PANEL_PASSWORD=change-me
#WEB_PANEL_BYPASS_AUTH=true    # start the panel with NO authentication (trusted networks only)
#PORT=8080                     # panel port (OAuth redirect URIs use this port)

# ─── Everything below is OPTIONAL when using the panel ───────────────────────
# ENV values seed the initial configuration; anything changed in the panel is
# stored in config/settings.json and takes precedence afterwards.

# API credentials (or enter them in the setup wizard instead)
# Spotify app  — https://developer.spotify.com/dashboard  (owner needs Premium)
#   redirect URI:  http://127.0.0.1:8080/callback/spotify   ("localhost" is rejected — use 127.0.0.1)
# TIDAL app    — https://developer.tidal.com/dashboard
#   scopes: playlists.read, playlists.write, user.read
#   redirect URI:  http://127.0.0.1:8080/callback/tidal
#SPOTIFY_CLIENT_ID=
#SPOTIFY_CLIENT_SECRET=
#TIDAL_CLIENT_ID=
#TIDAL_CLIENT_SECRET=

# Sync behavior
#SYNC_MODE=one-way             # one-way (source → mirror) | two-way (adds/removals propagate both ways)
#SYNC_SOURCE=spotify           # one-way only: which platform is the source of truth (spotify | tidal)
#SYNC_PLAYLISTS=all            # "all", or comma-separated playlist ids; "primaryId:secondaryId" links existing pairs
#SYNC_PERIODIC=true            # false = no schedule; sync only from the panel or "musicsync sync-once"
#SYNC_CRON=0 */6 * * *         # schedule (when periodic)
#SYNC_ON_START=true            # sync immediately when the service starts
#SYNC_TZ=Europe/Berlin         # timezone for the cron expression (default: system)

# Fine-tuning
#SPOTIFY_MARKET=US             # market for Spotify search
#TIDAL_ACCESS_TYPE=UNLISTED    # created TIDAL playlists: PUBLIC | UNLISTED (TIDAL has no private playlists)
#SPOTIFY_PLAYLIST_PUBLIC=false # created Spotify playlists public?
#DRY_RUN=false                 # log the diff, write nothing
#LOG_LEVEL=info                # debug | info | warn | error
#MATCH_RETRY_RUNS=10           # re-try unmatched tracks every N runs
#CONFIG_DIR=/config            # tokens/state/settings location (uncomment and set ./config for non-Docker runs)

# Headless CLI auth fallback ("musicsync auth", for installs without the panel)
#AUTH_PORT=8888
#AUTH_BIND=127.0.0.1           # Docker image overrides both binds to 0.0.0.0
#PANEL_BIND=127.0.0.1
