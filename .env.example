# ─── Spotify app (create your own at https://developer.spotify.com/dashboard) ──
# NOTE (2026 rules): the app owner must hold an active Spotify Premium
# subscription; one Development Mode app per developer, max 5 users.
# Add this redirect URI to the app settings:
#   http://127.0.0.1:8888/callback/spotify
# ("localhost" is NOT accepted by Spotify — use the literal 127.0.0.1.)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── TIDAL app (create at https://developer.tidal.com/dashboard) ──────────────
# Enable scopes: playlists.read, playlists.write, user.read
# Add redirect URI: http://127.0.0.1:8888/callback/tidal
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=

# ─── What to sync ─────────────────────────────────────────────────────────────
# Which platform is the source of truth. The other side is a mirror that
# musicsync fully owns: manual edits there are overwritten.
SYNC_MASTER=spotify            # spotify | tidal

# Comma-separated master playlist ids.
#   "all"                 -> every playlist owned by the master account
#   "<masterId>"          -> auto-create the mirror playlist on first sync
#   "<masterId>:<slaveId>"-> mirror into an existing slave playlist
SYNC_PLAYLISTS=all

# ─── Schedule ─────────────────────────────────────────────────────────────────
SYNC_CRON=0 */6 * * *          # cron expression (default: every 6 hours)
SYNC_ON_START=true             # also sync immediately on container start
#SYNC_TZ=Europe/Berlin         # timezone for the cron expression (default: system)

# ─── Behavior ────────────────────────────────────────────────────────────────
SPOTIFY_MARKET=US              # market for Spotify search/relinking
TIDAL_ACCESS_TYPE=UNLISTED    # created TIDAL playlists: PUBLIC | UNLISTED (no PRIVATE exists)
SPOTIFY_PLAYLIST_PUBLIC=false  # created Spotify playlists public?
DRY_RUN=false                  # true = log the diff, write nothing
LOG_LEVEL=info                 # debug | info | warn | error
MATCH_RETRY_RUNS=10            # re-try unmatched tracks every N runs
#CONFIG_DIR=/config            # tokens/state/reports location (uncomment and set ./config for non-Docker runs)
#AUTH_PORT=8888                # loopback port for the one-time OAuth bootstrap
#AUTH_BIND=127.0.0.1           # bootstrap bind address (Docker image overrides to 0.0.0.0)
